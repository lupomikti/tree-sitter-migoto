    "folds": {
      "fold": "Where to start a fold region"
    }
  },
  "supported_abi_versions": {
    "start": 13,
    "end": 15
  },
  "valid_predicates": {
    "eq": {
      "parameters": [
        {
          "type": "capture",
          "arity": "required"
        },
        {
          "type": "any",
          "arity": "required"
        }
      ],
      "description": "Checks for equality between two nodes, or a node and a string.",
      "any": true
    },
    "match": {
      "parameters": [
        {
          "type": "capture",
          "arity": "required"
        },
        {
          "type": "string",
          "arity": "required"
        }
      ],
      "description": "Uses regular expressions to match against the capture's text",
      "any": true
    },
    "is": {
      "parameters": [
        {
          "type": "string",
          "arity": "required"
        }
      ],
      "description": "Asserts that a capture has a given property",
      "not": false
    },
    "is-not": {
      "parameters": [
        {
          "type": "string",
          "arity": "required"
        }
      ],
      "description": "Asserts that a capture does not have a given property",
      "not": false
    }
  }
}