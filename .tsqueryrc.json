  "parser_install_directories": ["${HOME}/.config/helix/runtime/grammars"],
  "parser_aliases": {
    "ecma": "javascript"
  },
  "language_retrieval_patterns": [
    "tree-sitter-([^/]+)/.topiary/queries/[^/]+\\.scm$",
    "tree-sitter-([^/]+)/queries/[^/]+/[^/]+\\.scm$",
    "tree-sitter-([^/]+)/queries/[^/]+\\.scm$",
    "queries/([^/]+)/[^/]+\\.scm$"
  ],
